{
  "name": "customers",
  "description": "客户信息数据模型",
  "fields": [
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "客户名称"
    },
    {
      "name": "contact_person",
      "type": "string",
      "required": true,
      "description": "联系人"
    },
    {
      "name": "phone",
      "type": "string",
      "required": true,
      "description": "联系电话"
    },
    {
      "name": "email",
      "type": "string",
      "required": false,
      "description": "邮箱地址"
    },
    {
      "name": "company",
      "type": "string",
      "required": false,
      "description": "公司名称"
    },
    {
      "name": "industry",
      "type": "string",
      "required": false,
      "description": "行业"
    },
    {
      "name": "address",
      "type": "string",
      "required": false,
      "description": "地址"
    },
    {
      "name": "status",
      "type": "string",
      "required": true,
      "description": "客户状态：潜在、跟进中、已成交、已流失",
      "enum": ["潜在", "跟进中", "已成交", "已流失"]
    },
    {
      "name": "level",
      "type": "string",
      "required": true,
      "description": "客户级别：A（重点）、B（重要）、C（一般）",
      "enum": ["A", "B", "C"]
    },
    {
      "name": "source",
      "type": "string",
      "required": false,
      "description": "客户来源（直客/中介/展会/网络推广/客户介绍等）"
    },
    {
      "name": "remark",
      "type": "string",
      "required": false,
      "description": "备注"
    },
    {
      "name": "salesperson_id",
      "type": "string",
      "required": true,
      "description": "销售员ID"
    },
    {
      "name": "salesperson_name",
      "type": "string",
      "required": true,
      "description": "销售员姓名"
    },
    {
      "name": "scale",
      "type": "string",
      "required": false,
      "description": "企业规模（大型、中型、小型）",
      "enum": ["大型", "中型", "小型"]
    },
    {
      "name": "risk_level",
      "type": "string",
      "required": false,
      "description": "风险等级（高、中、低）",
      "enum": ["高", "中", "低"]
    },
    {
      "name": "relationship_strength",
      "type": "string",
      "required": false,
      "description": "关系强度（强、中、弱）",
      "enum": ["强", "中", "弱"]
    },
    {
      "name": "credit_code",
      "type": "string",
      "required": false,
      "description": "统一社会信用代码"
    },
    {
      "name": "legal_representative",
      "type": "string",
      "required": false,
      "description": "法定代表人"
    },
    {
      "name": "business_scope",
      "type": "string",
      "required": false,
      "description": "经营范围（主营业务）"
    },
    {
      "name": "registered_capital",
      "type": "string",
      "required": false,
      "description": "注册资本"
    },
    {
      "name": "establishment_date",
      "type": "string",
      "required": false,
      "description": "成立日期"
    },
    {
      "name": "created_at",
      "type": "datetime",
      "required": true,
      "description": "创建时间"
    },
    {
      "name": "updated_at",
      "type": "datetime",
      "required": true,
      "description": "更新时间"
    }
  ]
}