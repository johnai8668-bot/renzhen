      "required": false
    },
    {
      "name": "location",
      "type": "string",
      "description": "培训地点",
      "required": false
    },
    {
      "name": "trainingMethod",
      "type": "string",
      "description": "培训方式（线下/线上/混合）",
      "required": false
    },
    {
      "name": "notes",
      "type": "string",
      "description": "备注信息",
      "required": false
    },
    {
      "name": "createdAt",
      "type": "string",
      "description": "创建时间",
      "required": false
    },
    {
      "name": "updatedAt",
      "type": "string",
      "description": "更新时间",
      "required": false
    }
